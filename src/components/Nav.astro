---
const links = [
  { href: '#understanding', label: 'Understanding' },
  { href: '#tesla', label: 'Tesla FSD & Cybercab' },
  { href: '#industrial', label: 'Industrial First' },
  { href: '#timeline', label: 'The Road Ahead' },
  { href: '#faq', label: 'FAQ' },
];
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/10 bg-ink/90 backdrop-blur-md"
  aria-label="Primary"
>
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 sm:h-[4.25rem] items-center justify-between gap-4">
      <a href="/" class="group flex items-center gap-2.5 min-w-0" aria-label="selfdriving.monster home">
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-blue-600 to-red-600"
          aria-hidden="true"
        >
          <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a2 2 0 0 1 2 2v1.1A7.002 7.002 0 0 1 19 12v2a3 3 0 0 1-3 3h-1.17l-.83 2.5A1 1 0 0 1 13.06 20h-2.12a1 1 0 0 1-.94-.69L9.17 17H8a3 3 0 0 1-3-3v-2a7.002 7.002 0 0 1 5-6.9V4a2 2 0 0 1 2-2Zm-3.5 11.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm7 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
            ></path>
          </svg>
        </span>
        <span class="font-display text-xl sm:text-2xl font-semibold tracking-tighter truncate">
          selfdriving<span class="text-ember">.monster</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-7 text-sm font-medium">
        {
          links.map((link) => (
            <a href={link.href} class="text-zinc-400 hover:text-white transition-colors">
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2 sm:gap-3">
        <a
          href="#acquire"
          class="hidden sm:inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-white text-ink hover:bg-zinc-100 transition active:scale-[0.985]"
        >
          Acquire domain
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-xl border border-white/15 text-zinc-300 hover:text-white hover:bg-white/5"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-ink/98" hidden>
    <div class="mx-auto max-w-screen-2xl px-4 py-4 flex flex-col gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="mobile-link rounded-xl px-3 py-3 text-base text-zinc-200 hover:bg-white/5"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#acquire"
        class="mobile-link mt-2 rounded-xl px-3 py-3 text-center font-semibold bg-white text-ink"
      >
        Acquire domain
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener(
    'scroll',
    () => {
      if (!nav) return;
      if (window.scrollY > 24) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    },
    { passive: true },
  );

  function setMenu(open: boolean) {
    if (!btn || !menu) return;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.classList.toggle('hidden', !open);
    menu.hidden = !open;
  }

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') !== 'true';
    setMenu(open);
  });

  menu?.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });
</script>
