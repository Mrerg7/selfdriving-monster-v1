---
import { getCollection, render } from 'astro:content';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
---

<section id="faq" class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-14 sm:py-16 border-t border-white/10">
  <div class="max-w-3xl mx-auto">
    <h2 class="section-header tracking-tighter mb-8 text-center">Straight Answers to Real Questions</h2>

    <div class="space-y-3">
      {
        await Promise.all(
          faqs.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <details class="group bg-ink-soft border border-white/10 rounded-2xl px-5 sm:px-7 py-4 sm:py-5">
                <summary class="font-medium cursor-pointer flex justify-between items-center gap-4 text-[15px] sm:text-base list-none [&::-webkit-details-marker]:hidden">
                  <span>{entry.data.question}</span>
                  <span
                    class="shrink-0 text-zinc-500 group-open:rotate-45 transition-transform text-xl leading-none"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="mt-3 text-sm text-zinc-400 leading-relaxed">
                  <Content />
                </div>
              </details>
            );
          }),
        )
      }
    </div>
  </div>
</section>
