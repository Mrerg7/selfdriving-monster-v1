---
import { getCollection } from 'astro:content';

const stats = (await getCollection('stats')).sort((a, b) => a.data.order - b.data.order);
---

<div class="border-y border-white/10 bg-ink-elevated/80">
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-6 sm:py-7">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 text-center">
      {
        stats.map((stat) => (
          <div>
            <div class="text-2xl sm:text-3xl font-semibold tabular-nums tracking-tight">
              {stat.data.value}
              {stat.data.unit && (
                <span class="text-sm sm:text-base font-normal text-zinc-500"> {stat.data.unit}</span>
              )}
            </div>
            <div class="text-[11px] sm:text-xs text-zinc-500 mt-1.5 tracking-wide leading-snug">
              {stat.data.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
