---
const levels = [
  {
    level: 'LEVEL 0',
    title: 'No Automation',
    body: 'Human does everything. Most cars on the road today.',
    tone: 'zinc',
  },
  {
    level: 'LEVEL 1',
    title: 'Driver Assistance',
    body: 'Either steering OR acceleration/braking (adaptive cruise or lane keep).',
    tone: 'emerald',
  },
  {
    level: 'LEVEL 2',
    title: 'Partial Automation',
    body: 'System steers + accelerates/brakes (Tesla FSD, Super Cruise). Human must supervise.',
    tone: 'blue',
    badge: 'TODAY',
    ring: true,
  },
  {
    level: 'LEVEL 3',
    title: 'Conditional Automation',
    body: 'System drives in specific conditions. Human ready to intervene. Rare in production.',
    tone: 'amber',
  },
  {
    level: 'LEVEL 4',
    title: 'High Automation',
    body: 'All driving tasks within a defined domain. No human needed. Waymo, Zoox, Tesla Robotaxi ops.',
    tone: 'emerald-strong',
    badge: 'ROBOTAXIS',
    ringStrong: true,
  },
];

const badgeClass: Record<string, string> = {
  zinc: 'bg-zinc-800 text-zinc-400',
  emerald: 'bg-emerald-900/60 text-emerald-400',
  blue: 'bg-blue-600 text-white',
  amber: 'bg-amber-900/60 text-amber-400',
  'emerald-strong': 'bg-emerald-600 text-white',
};
---

<section id="understanding" class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 pt-16 sm:pt-20 pb-12">
  <div class="max-w-3xl mb-10">
    <div class="uppercase text-signal text-xs tracking-[0.2em] font-semibold mb-3">Foundation</div>
    <h2 class="section-header tracking-tighter">What “Self-Driving” Actually Means</h2>
    <p class="mt-3 text-base sm:text-lg text-zinc-400">
      The SAE levels are the global standard. Most consumer systems today are still Level 2. True
      robotaxis operate at Level 4 — within carefully defined areas.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3 sm:gap-4">
    {
      levels.map((item) => (
        <div
          class:list={[
            'tech-surface p-5 sm:p-6',
            item.ring && 'ring-1 ring-blue-500/30',
            item.ringStrong && 'ring-1 ring-emerald-500/30',
          ]}
        >
          <div class="flex items-center justify-between mb-4 gap-2">
            <div class:list={['text-xs px-3 py-1 rounded-2xl font-mono', badgeClass[item.tone]]}>
              {item.level}
            </div>
            {item.badge && (
              <span
                class:list={[
                  'text-[10px] px-2 py-0.5 rounded',
                  item.tone === 'blue' ? 'bg-blue-600/20 text-blue-400' : 'bg-emerald-600/20 text-emerald-400',
                ]}
              >
                {item.badge}
              </span>
            )}
          </div>
          <div class="font-semibold text-base sm:text-lg mb-1">{item.title}</div>
          <div class="text-sm text-zinc-400 leading-relaxed">{item.body}</div>
        </div>
      ))
    }
  </div>

  <p class="mt-6 text-xs text-zinc-500 max-w-2xl">
    Level 5 does not yet exist commercially. Headlines often conflate Level 2 supervised systems with
    true driverless capability.
  </p>
</section>
