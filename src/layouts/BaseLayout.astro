---
import '../styles/global.css';
import { SITE, HERO_IMAGE, OG_IMAGE, FAVICON_IMAGE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = OG_IMAGE,
  canonical = SITE.url,
  jsonLd = [],
} = Astro.props;

const schemas = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={SITE.keywords.join(', ')} />
    <meta name="author" content={SITE.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#07080c" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={FAVICON_IMAGE} type="image/png" />
    <link rel="apple-touch-icon" href={FAVICON_IMAGE} />
    <link rel="shortcut icon" href={FAVICON_IMAGE} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:alt" content="Autonomous vehicle — selfdriving.monster" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Autonomous vehicle — selfdriving.monster" />

    <!-- Preconnect Cloudflare Images CDN -->
    <link rel="preconnect" href="https://imagedelivery.net" crossorigin />
    <link rel="dns-prefetch" href="https://imagedelivery.net" />

    <!-- LCP preload for hero -->
    <link rel="preload" as="image" href={HERO_IMAGE} fetchpriority="high" />

    <title>{title}</title>

    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body class="min-h-dvh">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:bg-white focus:text-ink focus:px-4 focus:py-2 focus:rounded-lg"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
