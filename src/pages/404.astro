---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page not found — selfdriving.monster';
---

<BaseLayout title={title} description="The page you requested could not be found.">
  <main class="min-h-dvh flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="font-display text-2xl tracking-tighter">
        selfdriving<span class="text-ember">.monster</span>
      </p>
      <h1 class="mt-6 text-4xl font-display font-bold tracking-tighter">404</h1>
      <p class="mt-3 text-zinc-400">That route doesn’t exist on this map.</p>
      <a
        href="/"
        class="mt-8 inline-flex rounded-2xl bg-white px-6 py-3 text-ink font-semibold text-sm hover:bg-zinc-100 transition"
      >
        Back home
      </a>
    </div>
  </main>
</BaseLayout>
